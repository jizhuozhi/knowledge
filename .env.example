# =============================================
# Knowledge Platform Configuration
# =============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# =============================================

# Application
APP_NAME=knowledge-platform
APP_ENV=development
APP_PORT=8080
DEBUG=true
APP_VERSION=1.0.0

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=knowledge_db
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=10

# OpenSearch
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false

# Neo4j (Graph Database)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================
# LLM Configuration (AWS Bedrock)
# =============================================
LLM_PROVIDER=bedrock

# AWS Credentials
# Option 1: Set credentials here
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=  # Optional, for temporary credentials
#
# Option 2: Use AWS credentials file (~/.aws/credentials)
# Leave AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY empty,
# and mount ~/.aws in docker-compose.yml

# Embedding Model
# Available models:
#   - amazon.titan-embed-text-v2:0 (1024 dimensions, recommended)
#   - amazon.titan-embed-text-v1   (1536 dimensions)
EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
EMBEDDING_DIMENSION=1024

# Chat Model
# Nova Models (Recommended):
#   - amazon.nova-micro-v1:0  (fastest, text only)
#   - amazon.nova-lite-v1:0   (multimodal, cost-effective)
#   - amazon.nova-pro-v1:0    (multimodal, most capable)
# Titan Models:
#   - amazon.titan-text-lite-v1     (lightweight)
#   - amazon.titan-text-express-v1  (general purpose)
CHAT_MODEL=amazon.nova-micro-v1:0

# =============================================
# Tenant & Document
# =============================================
TENANT_ISOLATION_MODE=row

# Document processing
MAX_FILE_SIZE=104857600
UPLOAD_DIR=./uploads
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Static files (frontend)
# The Go server serves frontend static files directly (no nginx needed)
# In Docker: /app/static (automatically set in Dockerfile)
# Local dev: ./frontend/dist (run `cd frontend && npm run build` first)
STATIC_DIR=./frontend/dist
